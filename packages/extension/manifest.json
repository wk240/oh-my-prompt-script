{
  "manifest_version": 3,
  "name": "Oh My Prompt",
  "version": "2.0.0",
  "description": "一键插入预设提示词，提升创作效率",
  "homepage_url": "https://oh-my-prompt.com/",
  "content_security_policy": {
    "extension_pages": "script-src 'self' http://localhost:5173; object-src 'self'"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/core/coordinator.ts"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/auth/callback*",
        "http://localhost:3000/auth/extension/callback*",
        "http://localhost:3000/auth/extension/sync*",
        "https://oh-my-prompt.com/auth/callback*",
        "https://oh-my-prompt.com/auth/extension/callback*",
        "https://oh-my-prompt.com/auth/extension/sync*"
      ],
      "js": [
        "src/content/auth-callback.ts"
      ],
      "run_at": "document_start"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "tabs",
    "alarms",
    "contextMenus",
    "sidePanel",
    "scripting",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*",
    "https://*/*",
    "http://localhost:3000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon-16.png",
        "assets/icon-48.png",
        "assets/icon-128.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
