{
  "manifest_version": 3,
  "name": "Oh My Prompt Script",
  "version": "1.1.0",
  "description": "一键插入预设提示词，提升创作效率",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content-script.ts-loader-1ihs-W22.js"
      ],
      "matches": [
        "*://lovart.ai/*",
        "*://*.lovart.ai/*",
        "file:///*"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/settings.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/icon-16.png",
        "assets/icon-48.png",
        "assets/icon-128.png"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://*.lovart.ai/*",
        "*://lovart.ai/*",
        "file:///*"
      ],
      "resources": [
        "assets/messages-ATzc5Kiq.js",
        "assets/messages-ATzc5Kiq.js.map",
        "assets/x-BHidqGbR.js",
        "assets/x-BHidqGbR.js.map",
        "assets/store-yqu5WsQz.js",
        "assets/store-yqu5WsQz.js.map",
        "assets/sync-manager-RGd8ChU2.js",
        "assets/sync-manager-RGd8ChU2.js.map",
        "assets/folder-open-CQmWVo0-.js",
        "assets/folder-open-CQmWVo0-.js.map",
        "assets/content-script.ts-Bd3qD_HU.js",
        "assets/content-script.ts-Bd3qD_HU.js.map"
      ],
      "use_dynamic_url": false
    }
  ]
}
