{
  "manifest_version": 3,
  "name": "Prompt-Script",
  "version": "1.0.0",
  "description": "一键插入预设提示词，提升创作效率",
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://lovart.ai/*",
        "*://*.lovart.ai/*",
        "file:///*"
      ],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/settings.html"
  },
  "permissions": ["activeTab", "downloads", "storage", "tabs"]
}