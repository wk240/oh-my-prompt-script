{
  "manifest_version": 3,
  "name": "Oh My Prompt Script",
  "version": "1.1.2",
  "description": "一键插入预设提示词，提升创作效率",
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://lovart.ai/*",
        "*://*.lovart.ai/*",
        "file:///*"
      ],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/settings.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["activeTab", "downloads", "storage", "tabs", "alarms"],
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icon-16.png", "assets/icon-48.png", "assets/icon-128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}